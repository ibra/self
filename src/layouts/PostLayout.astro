---
const { frontmatter } = Astro.props;
import "../styles/global.css";
import "../styles/post.css";
import Nav from "@components/Nav.astro";
import Container from "@components/Container.astro";
import Heading from "@components/Heading.astro";
import FloatingPixels from "@components/FloatingPixels.astro";

const isPoetry = frontmatter.tags?.includes("poems");
---

<html lang="en">
  <head>
    <title>{Astro.props.title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="robots" content="follow, index" />
    <meta
      content="ibrahim hisham. programmer and hobbyist independent game developer. Rust, C#, Typescript."
      name="description"
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ibrahim hisham" />
    <meta
      property="og:description"
      content="ibrahim hisham. programmer & hobbyist independent game developer. Rust, C#, Typescript."
    />
    <meta property="og:title" content={Astro.props.title} />
    <meta
      property="og:image"
      content="https://avatars.githubusercontent.com/u/61324615?v=4"
    />
    <meta name="theme-color" content="#050505" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#050505]">
    <FloatingPixels />
    <div
      class={`flex min-h-screen items-center justify-center py-16 px-4 sm:px-6 lg:px-10`}
    >
      <div class="w-full max-w-xl min-h-[60vh] px-4 py-6 md:px-8 md:py-8 lg:px-10 overflow-x-auto">
        <Nav />
        <Heading title={frontmatter.title} />
        <p class="stagger-100 animate-fade text-slate-400 text-lg mb-3 italic">
          {
            new Date(frontmatter.date)
              .toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
              .replace(/,/, "")
          }
        </p>
        {(frontmatter.tags?.length > 0 || frontmatter.archive) && (
          <div class="flex gap-2 mb-5 stagger-150 animate-fade">
            {frontmatter.archive && (
              <span class="text-xs text-slate-200 border border-slate-100 rounded px-2 py-1">
                archived
              </span>
            )}
            {frontmatter.tags?.map((tag: string) => (
              <span class="text-xs text-slate-500 border border-slate-700 rounded px-2 py-1">
                {tag}
              </span>
            ))}
          </div>
        )}
        {isPoetry && (
          <button
            id="poetry-fit-toggle"
            class="hidden text-xs px-3 py-1.5 mb-5 rounded border border-slate-600 text-slate-400 hover:text-white hover:border-white transition-all duration-300"
          >
            fit to screen
          </button>
        )}
        <div class={`post-content overflow-x-auto ${isPoetry ? 'poetry' : ''}`}>
          <slot />
        </div>
      </div>
    </div>
    {isPoetry && (
      <script>
        const toggle = document.getElementById('poetry-fit-toggle');
        const content = document.querySelector('.post-content.poetry');
        if (toggle && content) {
          function checkOverflow() {
            if (!content.classList.contains('fitted')) {
              const overflows = content.scrollWidth > content.clientWidth;
              toggle.classList.toggle('hidden', !overflows);
            }
          }

          checkOverflow();
          window.addEventListener('resize', checkOverflow);

          toggle.addEventListener('click', () => {
            const fitting = !content.classList.contains('fitted');
            content.classList.toggle('fitted', fitting);
            const paragraphs = content.querySelectorAll('p');

            if (fitting) {
              const ratio = content.clientWidth / content.scrollWidth;
              const base = parseFloat(getComputedStyle(paragraphs[0]).fontSize);
              const scaled = Math.floor(base * ratio * 100) / 100;
              paragraphs.forEach(p => p.style.fontSize = scaled + 'px');
            } else {
              paragraphs.forEach(p => p.style.fontSize = '');
            }

            toggle.textContent = fitting ? 'original' : 'fit to screen';
            toggle.classList.toggle('border-white', fitting);
            toggle.classList.toggle('text-white', fitting);
            toggle.classList.toggle('border-slate-600', !fitting);
            toggle.classList.toggle('text-slate-400', !fitting);
            if (!fitting) checkOverflow();
          });
        }
      </script>
    )}
  </body>
</html>
