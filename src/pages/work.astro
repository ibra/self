---
import DetailModal from "@components/DetailModal.astro";
import Nav from "@components/Nav.astro";
import Layout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import Heading from "@components/Heading.astro";

const poetryPosts = await Astro.glob("./poetry/**/*.md");
const sortedPoetry = poetryPosts
  .sort(
    (a, b) =>
      (new Date(b.frontmatter.date) as any) -
      (new Date(a.frontmatter.date) as any)
  )
  .slice(0, 4);

const categories = [
  {
    name: "games",
    items: [
      {
        title: "fogbound",
        description:
          "narrative-driven psychological horror game set in a toxic, fog-ridden lahore.",
        url: "https://store.steampowered.com/app/4140990/FOGBOUND/",
        metadata: "2025, Steam",
        delay: 150,
      },
      {
        title: "pointblank",
        description:
          "fast-paced twin-stick shooter where you have a single bullet.",
        url: "https://store.steampowered.com/app/1221330/Pointblank",
        metadata: "2020, Steam",
        delay: 250,
      },
      {
        title: "more... (itch.io)",
        description:
          "collection of various little games made for jams and competitions.",
        url: "https://ibrahh.itch.io",
        metadata: "itch.io",
        delay: 350,
      },
    ],
  },
  {
    name: "software",
    items: [
      {
        title: "lachesis",
        description:
          "lightweight cross-platform time-tracking application written in rust.",
        url: "https://github.com/ibra/lachesis",
        metadata: "2024, Rust",
        delay: 150,
      },
      {
        title: "snip.tf",
        description:
          "a modern, minimalistic pastebin. developed backend in rust, deployed on the edge.",
        url: "https://snip.tf/",
        metadata: "2024, Rust",
        delay: 250,
      },
      {
        title: "ibralogue",
        description:
          "robust, extensible dialogue framework for the unity game engine.",
        url: "https://github.com/Ibralogue/Ibralogue",
        metadata: "2021, C#",
        delay: 350,
      },
    ],
  },
];
---

<Layout title="ibrahim hisham ~ work" padding="32" path="/work">
  <Container>
    <Nav />
    <Heading title="work" styling="stagger-50" />
    <p class="stagger-100 animate-fade text-lg mb-5">
      trying to find signal.
    </p>

    <div class="flex flex-wrap gap-3 mb-6" id="category-buttons">
      {
        categories.map((cat, index) => (
          <button
            class="category-btn text-sm md:text-base px-4 py-2 rounded border border-slate-600 text-slate-400 hover:text-white hover:border-white transition-all duration-300"
            data-index={index}
          >
            {cat.name}
          </button>
        ))
      }
    </div>

    <div id="category-panels" class="relative w-full overflow-hidden transition-all duration-300 ease-in-out">
      {
        categories.map((cat, index) => (
          <ul
            class="category-panel absolute top-0 left-0 w-full flex flex-col transition-opacity duration-500 ease-in-out"
            style={`opacity: ${index === 0 ? "1" : "0"}; pointer-events: ${index === 0 ? "auto" : "none"}`}
            data-index={index}
          >
            {cat.items.map((item) => (
              <DetailModal
                title={item.title}
                description={item.description}
                url={item.url}
                delay={item.delay}
              />
            ))}
          </ul>
        ))
      }
    </div>

    <script type="module">
      const buttons = document.querySelectorAll(".category-btn");
      const panels = document.querySelectorAll(".category-panel");
      const container = document.getElementById("category-panels");
      let active = 0;

      function calculateMaxHeight() {
        let maxHeight = 0;
        panels.forEach((panel) => {
          // temporarily show panel to measure its height
          panel.style.position = "static";
          panel.style.opacity = "1";
          panel.style.pointerEvents = "auto";
          const height = panel.offsetHeight;
          maxHeight = Math.max(maxHeight, height);

          // hide it again
          panel.style.position = "absolute";
          panel.style.opacity = panel.dataset.index == active ? "1" : "0";
          panel.style.pointerEvents = panel.dataset.index == active ? "auto" : "none";
        });
        container.style.height = `${maxHeight}px`;
      }

      function setActive(index) {
        // First, measure the target panel's height
        const targetPanel = panels[index];
        targetPanel.style.position = "static";
        targetPanel.style.opacity = "1";
        const targetHeight = targetPanel.offsetHeight;
        targetPanel.style.position = "absolute";
        
        // Update container height smoothly
        container.style.height = `${targetHeight}px`;

        buttons.forEach((btn, i) => {
          btn.classList.toggle("border-white", i === index);
          btn.classList.toggle("text-white", i === index);
          btn.classList.toggle("border-slate-600", i !== index);
          btn.classList.toggle("text-slate-400", i !== index);
        });

        panels.forEach((panel, i) => {
          if (i === index) {
            panel.style.opacity = "1";
            panel.style.pointerEvents = "auto";
          } else {
            panel.style.opacity = "0";
            panel.style.pointerEvents = "none";
          }
        });
      }

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const index = parseInt(btn.dataset.index);
          if (index === active) return;
          setActive(index);
          active = index;
        });
      });

      // Initialize after content loads
      window.addEventListener("load", () => {
        calculateMaxHeight();
        setActive(0);
      });

      // Recalculate on window resize
      window.addEventListener("resize", calculateMaxHeight);
    </script>
  </Container>
</Layout>