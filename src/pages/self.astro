---
import Nav from "@components/Nav.astro";
import Layout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import Heading from "@components/Heading.astro";
---

<Layout title="ibrahim hisham ~ self" padding="32" path="self">
  <Container>
    <Nav />
    <Heading title="self" styling="stagger-50" />
    <p class="stagger-100 animate-fade text-lg mb-5">
      i'm there, somewhat.
    </p>

    <ul
      class="text-slate-400 antialised text-base animate-fade stagger-150 grid grid-cols-2 mb-8"
    >
      <li>
        github <br />
        <a
          href="https://github.com/ibra"
          class="text-slate-200 hover:text-slate-400">/ibra</a
        >
      </li>
      <li>
        itch.io <br />
        <a
          href="https://ibrahh.itch.io"
          class="text-slate-200 hover:text-slate-400">/ibrahh</a
        >
      </li>
      <li>
        bluesky <br />
        <a
          href="https://bsky.app/profile/ibrhm.bsky.social"
          class="text-slate-200 hover:text-slate-400">@ibrhm</a
        >
      </li>
      <li>
        discord <br />
        <a
          href="https://discordapp.com/users/745039444888780812"
          class="text-slate-200 hover:text-slate-400">@ibra_h</a
        >
      </li>
    </ul>

    <Heading title="about" styling="stagger-200" />

    <div class="text-slate-400 antialised leading-relaxed mb-5">


      <p class="animate-fade stagger-250 text-lg mt-5">
        i'm ibrahim hisham, ibra, or <a
          href="https://instagram.com/generatednoise"
          class="text-slate-200 hover:text-slate-400">@generatednoise</a
        >.
      </p>
      <p class="animate-fade stagger-300 text-lg mt-5">
        by day, i love designing video games and working on systems-centric applications and other practical software.
      </p>

      <p class="animate-fade stagger-300 text-lg mt-5">
        in my spare time i'm usually thinking about poetry, philosophy, or <a
          href="https://letterboxd.com/ibrahh/"
          class="text-slate-200 hover:text-slate-400">film</a
        >.
      </p>

      <p class="animate-fade stagger-350 text-lg mt-5">
      </p>

      <p class="animate-fade stagger-450 text-lg mt-5">
        if you have something for me, feel free to <a
          href="mailto:ibrahim.hisham@proton.me"
          class="text-slate-200 hover:text-slate-400">reach out</a
        >.
      </p>
    </div>
  </Container>
</Layout>